+'use client'
+
+import { useEffect, useState } from 'react'
+import { AppShell } from '@/components/app-shell'
+import { ActivityIcon, AlertTriangleIcon, CircleOffIcon, DatabaseIcon, ShieldCheckIcon } from '@/components/icons'
+import { api } from '@/lib/api'
+import type { MetricsResponse } from '@/lib/types'
+
+export default function AnalyticsPage() {
+  const [metrics, setMetrics] = useState<MetricsResponse | null>(null)
+  const [auditCount, setAuditCount] = useState(0)
+
+  useEffect(() => {
+    const load = async () => {
+      try {
+        const [dashboardMetrics, audit] = await Promise.all([
+          api.dashboard.getMetrics(),
+          api.audit.getLogs({ page: 1, limit: 5 }),
+        ])
+        setMetrics(dashboardMetrics)
+        setAuditCount(audit.pagination?.total || 0)
+      } catch {}
+    }
+    void load()
+  }, [])
+
+  return (
+    <AppShell title="Analytics" subtitle="Operational rollup of activity, usage, and control posture.">
+      <div className="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-5 gap-6">
+        <div className="glass-card rounded-xl p-6"><ActivityIcon className="w-8 h-8 text-primary-400 mb-4" /><p className="text-sm text-dark-400">Active Lines</p><p className="text-3xl font-bold mt-1">{metrics?.activeLines ?? '--'}</p></div>
+        <div className="glass-card rounded-xl p-6"><DatabaseIcon className="w-8 h-8 text-accent-400 mb-4" /><p className="text-sm text-dark-400">Usage Volume (GB)</p><p className="text-3xl font-bold mt-1">{metrics?.totalUsageGB ?? '--'}</p></div>
+        <div className="glass-card rounded-xl p-6"><CircleOffIcon className="w-8 h-8 text-slate-400 mb-4" /><p className="text-sm text-dark-400">Terminated</p><p className="text-3xl font-bold mt-1">{metrics?.terminatedLines ?? '--'}</p></div>
+        <div className="glass-card rounded-xl p-6"><AlertTriangleIcon className="w-8 h-8 text-amber-400 mb-4" /><p className="text-sm text-dark-400">Failed Provisioning</p><p className="text-3xl font-bold mt-1">{metrics?.failedLines ?? '--'}</p></div>
+        <div className="glass-card rounded-xl p-6"><ShieldCheckIcon className="w-8 h-8 text-emerald-400 mb-4" /><p className="text-sm text-dark-400">Audit Events</p><p className="text-3xl font-bold mt-1">{auditCount || '--'}</p></div>
+      </div>
+      <div className="glass-card rounded-xl p-6 mt-6"><h3 className="text-xl font-bold mb-3">What this view covers</h3><p className="text-dark-300 leading-7">This release now surfaces inventory posture across active, terminated, and failed states in addition to total usage and audit volume. It gives operators a tighter control-plane view without leaving the core app shell.</p></div>
+    </AppShell>
+  )
+}
