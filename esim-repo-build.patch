+
+  .btn-accent {
+    @apply px-6 py-3 bg-accent-600 hover:bg-accent-700 text-white font-medium rounded-lg
+           transition-all duration-200 shadow-lg shadow-accent-900/50
+           hover:shadow-xl hover:shadow-accent-900/60 hover:-translate-y-0.5;
