+  const [recentLines, setRecentLines] = useState<Line[]>([])
+  const [isLoading, setIsLoading] = useState(true)
+  useEffect(() => { if (!hasCheckedAuth) void checkAuth() }, [checkAuth, hasCheckedAuth])
+  useEffect(() => { if (hasCheckedAuth && !authLoading && !user) { router.push('/login'); return } if (user) void loadData() }, [user, authLoading, hasCheckedAuth, router])
+  const loadData = async () => { try { setIsLoading(true); const [dashboardMetrics, linesData] = await Promise.all([api.dashboard.getMetrics(), api.lines.list({ limit: 5 })]); setMetricsData(dashboardMetrics); setRecentLines(linesData.lines || []) } catch (error: any) { toast.error(error.response?.data?.error || 'Failed to load dashboard') } finally { setIsLoading(false) } }
+  const metrics = useMemo<MetricCard[]>(() => !metricsData ? [] : [{ label: 'Total Lines', value: metricsData.totalLines.toString(), change: '+12.5%', trend: 'up', icon: SmartphoneIcon }, { label: 'Active Lines', value: metricsData.activeLines.toString(), change: '+8.2%', trend: 'up', icon: ActivityIcon }, { label: 'Provisioning', value: metricsData.provisioningLines.toString(), change: '-3.1%', trend: 'down', icon: ZapIcon }, { label: 'Total Usage (GB)', value: metricsData.totalUsageGB.toString(), change: '+15.3%', trend: 'up', icon: TrendingUpIcon }], [metricsData])
+  if (authLoading || isLoading) return <div className="min-h-screen bg-gradient-to-br from-dark-950 via-dark-900 to-dark-950 flex items-center justify-center"><div className="text-center"><div className="w-16 h-16 border-4 border-primary-600 border-t-transparent rounded-full animate-spin mx-auto mb-4" /><p className="text-dark-400">Loading platform...</p></div></div>
+  return <AppShell title="Dashboard" subtitle="Monitor line inventory, provisioning throughput, and recent activity." actions={user?.role !== 'VIEWER' ? <Link href="/lines/new" className="btn-primary flex items-center gap-2"><PlusIcon className="w-4 h-4" />New Line</Link> : null}><div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">{metrics.map((metric) => { const Icon = metric.icon; return <div key={metric.label} className="metric-card"><div className="flex items-center justify-between mb-4"><div className={`p-3 rounded-lg ${metric.trend === 'up' ? 'bg-primary-500/10' : 'bg-dark-800'}`}><Icon className={`w-6 h-6 ${metric.trend === 'up' ? 'text-primary-400' : 'text-dark-400'}`} /></div><span className={`text-sm font-medium ${metric.trend === 'up' ? 'text-emerald-400' : 'text-red-400'}`}>{metric.change}</span></div><p className="text-dark-400 text-sm mb-1">{metric.label}</p><p className="text-3xl font-bold text-dark-50">{metric.value}</p></div>})}</div><div className="glass-card rounded-xl overflow-hidden"><div className="p-6 border-b border-dark-800 flex items-center justify-between"><div><h3 className="text-xl font-bold mb-1">Recent Lines</h3><p className="text-sm text-dark-400">Latest line activity across the tenant</p></div><Link href="/lines" className="text-primary-400 hover:text-primary-300 font-medium text-sm">View all lines →</Link></div><div className="overflow-x-auto"><table className="table"><thead><tr><th>MSISDN</th><th>Status</th><th>Plan</th><th>Usage</th><th>Last Update</th><th>Actions</th></tr></thead><tbody>{recentLines.length === 0 ? <tr><td colSpan={6} className="text-center py-10 text-dark-400">No recent line activity yet.</td></tr> : recentLines.map((line) => <tr key={line.id}><td className="font-mono font-medium">{line.msisdn || 'Provisioning...'}</td><td><span className={`badge ${statusColors[line.status]}`}>{line.status.toLowerCase()}</span></td><td>{getPlanName(line)}</td><td className="font-mono text-sm">{getUsage(line)}</td><td className="text-dark-400">{getTimeAgo(line.createdAt)}</td><td><Link href={`/lines/${line.id}`} className="text-primary-400 hover:text-primary-300 transition-colors text-sm font-medium">Manage →</Link></td></tr>)}</tbody></table></div></div><div className="grid grid-cols-1 md:grid-cols-3 gap-6 mt-8"><Link href="/analytics" className="glass-card p-6 rounded-xl hover:border-primary-600/50 transition-all cursor-pointer group"><BarChartIcon className="w-8 h-8 text-primary-400 mb-4 group-hover:scale-110 transition-transform" /><h4 className="font-bold mb-2">Usage Analytics</h4><p className="text-sm text-dark-400">Inspect demand trends and operational posture.</p></Link><div className="glass-card p-6 rounded-xl hover:border-primary-600/50 transition-all cursor-pointer group"><UsersIcon className="w-8 h-8 text-accent-400 mb-4 group-hover:scale-110 transition-transform" /><h4 className="font-bold mb-2">Tenant Operations</h4><p className="text-sm text-dark-400">Current build is scoped for line admins and operator workflows.</p></div><div className="glass-card p-6 rounded-xl hover:border-primary-600/50 transition-all cursor-pointer group"><SettingsIcon className="w-8 h-8 text-primary-400 mb-4 group-hover:scale-110 transition-transform" /><h4 className="font-bold mb-2">Platform Settings</h4><p className="text-sm text-dark-400">JWT auth, audit logging, queues, and webhook plumbing are in place.</p></div></div></AppShell>
