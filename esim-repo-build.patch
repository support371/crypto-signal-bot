assName="overflow-x-auto"><table className="table"><thead><tr><th>MSISDN</th><th>Status</th><th>Plan</th><th>Usage</th><th>Created</th><th>Actions</th></tr></thead><tbody>{isLoading ? <tr><td colSpan={6} className="text-center py-10 text-dark-400">Loading lines...</td></tr> : lines.length === 0 ? <tr><td colSpan={6} className="text-center py-10 text-dark-400">No lines match the current filter set.</td></tr> : lines.map((line) => <tr key={line.id}><td><div><p className="font-mono font-medium">{line.msisdn || 'Provisioning...'}</p><p className="text-xs text-dark-500 mt-1">{line.iccid || 'ICCID pending'}</p></div></td><td><span className={`badge ${statusColors[line.status]}`}>{line.status.toLowerCase()}</span></td><td>{getPlanName(line)}</td><td className="font-mono text-sm">{getUsage(line)}</td><td className="text-dark-400">{new Date(line.createdAt).toLocaleString()}</td><td><div className="flex flex-wrap items-center gap-2"><Link href={`/lines/${line.id}`} className="text-primary-400 hover:text-primary-300 transition-colors text-sm font-medium">Manage</Link>{canMutate && line.status === 'ACTIVE' ? <button onClick={() => void handleSuspend(line.id)} disabled={isMutating === line.id} className="text-sm text-amber-300 hover:text-amber-200 inline-flex items-center gap-1 disabled:opacity-50"><PauseIcon className="w-4 h-4" /> Suspend</button> : null}{canMutate && line.status === 'SUSPENDED' ? <button onClick={() => void handleResume(line.id)} disabled={isMutating === line.id} className="text-sm text-emerald-300 hover:text-emerald-200 inline-flex items-center gap-1 disabled:opacity-50"><PlayIcon className="w-4 h-4" /> Resume</button> : null}{canMutate && line.status !== 'TERMINATED' ? <button onClick={() => void handleTerminate(line.id)} disabled={isMutating === line.id} className="text-sm text-red-300 hover:text-red-200 inline-flex items-center gap-1 disabled:opacity-50"><XCircleIcon className="w-4 h-4" /> Terminate</button> : null}</div></td></tr>)}</tbody></table></div><