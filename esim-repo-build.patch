+'use client'
+
+import { useEffect, useState } from 'react'
+import { AppShell } from '@/components/app-shell'
+import { api } from '@/lib/api'
+import type { AuditLogRecord } from '@/lib/types'
+
+export default function AuditPage() {
+  const [logs, setLogs] = useState<AuditLogRecord[]>([])
+  const [page, setPage] = useState(1)
+  const [totalPages, setTotalPages] = useState(1)
+  const [isLoading, setIsLoading] = useState(true)
+  const [action, setAction] = useState('')
+  const [actor, setActor] = useState('')
+
+  useEffect(() => {
+    const loadLogs = async () => {
+      try {
+        setIsLoading(true)
+        const response = await api.audit.getLogs({ page, limit: 20, action: action || undefined, actor: actor || undefined })
+        setLogs(response.logs || [])
+        setTotalPages(response.pagination?.totalPages || 1)
+      } finally {
+        setIsLoading(false)
+      }
+    }
+
+    void loadLogs()
+  }, [page, action, actor])
+
+  return (
+    <AppShell title="Audit Trail" subtitle="Trace lifecycle actions, operators, and timestamps across the tenant control plane.">
+      <div className="glass-card rounded-xl p-5 mb-6 grid grid-cols-1 md:grid-cols-2 gap-4">
+        <input value={action} onChange={(e) => { setPage(1); setAction(e.target.value) }} className="input" placeholder="Filter by action" />
+        <input value={actor} onChange={(e) => { setPage(1); setActor(e.target.value) }} className="input" placeholder="Filter by actor email" />
+      </div>
+
+      <div className="glass-card rounded-xl overflow-hidden">
+        <div className="overflow-x-auto">
+          <table className="table">
+            <thead>
+              <tr>
+                <th>Action</th>
+                <th>Resource</th>
+                <th>Actor</th>
+                <th>Line</th>
+                <th>Timestamp</th>
+              </tr>
+            </thead>
+            <tbody>
+              {isLoading ? (
+                <tr>
+                  <td colSpan={5} className="text-center py-10 text-dark-400">Loading audit events...</td>
+                </tr>
+              ) : logs.length === 0 ? (
+                <tr>
+                  <td colSpan={5} className="text-center py-10 text-dark-400">No audit activity matches the current filter set.</td>
+                </tr>
+              ) : (
+                logs.map((log) => (
+                  <tr key={log.id}>
+                    <td className="font-medium">{log.action}</td>
+                    <td>{log.resource}</td>
+                    <td>{log.user?.firstName || log.user?.email || 'System'}</td>
+                    <td className="font-mono text-xs text-dark-400">{log.line?.msisdn || log.line?.id || '--'}</td>
+                    <td className="text-dark-400">{new Date(log.createdAt).toLocaleString()}</td>
+                  </tr>
+                ))
+              )}
+            </tbody>
+          </table>
+        </div>
+
+        <div className="p-4 border-t border-dark-800 flex items-center justify-between">
+          <span className="text-sm text-dark-400">Page {page} of {totalPages}</span>
+          <div className="flex items-center gap-2">
+            <button className="px-4 py-2 bg-dark-800 hover:bg-dark-700 rounded-lg transition-colors text-sm disabled:opacity-50" disabled={page <= 1} onClick={() => setPage((current) => Math.max(1, current - 1))}>
+              Previous
+            </button>
+            <button className="px-4 py-2 bg-primary-600 hover:bg-primary-700 rounded-lg transition-colors text-sm disabled:opacity-50" disabled={page >= totalPages} onClick={() => setPage((current) => Math.min(totalPages, current + 1))}>
+              Next
+            </button>
+          </div>
+        </div>
+      </div>
+    </AppShell>
+  )
+}
