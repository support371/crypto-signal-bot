+  const loadLines = async (pageOverride?: number) => { try { setIsLoading(true); const response = await api.lines.list({ page: pageOverride ?? page, limit: 10, status: selectedStatus, search: searchTerm }); setLines(response.lines || []); setTotalPages(response.pagination?.totalPages || 1) } catch (error: any) { toast.error(error.response?.data?.error || 'Failed to load lines') } finally { setIsLoading(false) } }
+  const handleSuspend = async (id: string) => { try { setIsMutating(id); await api.lines.suspend(id); await loadLines() } finally { setIsMutating(null) } }
