@@ -0,0 +1,41 @@
+import { Router, Request, Response } from 'express';
+import { prisma } from '../app';
+import { authMiddleware } from '../middleware/auth';
+import { logger } from '../lib/logger';
+
+const router = Router();
+router.use(authMiddleware);
+
+router.get('/metrics', async (req: Request, res: Response) => {
+  try {
+    const { tenantId } = (req as Request & { user: { tenantId: string } }).user;
+
+    const [totalLines, activeLines, provisioningLines, suspendedLines, terminatedLines, failedLines, totalUsage] = await Promise.all([
+      prisma.line.count({ where: { tenantId } }),
+      prisma.line.count({ where: { tenantId, status: 'ACTIVE' } }),
+      prisma.line.count({ where: { tenantId, status: 'PROVISIONING' } }),
+      prisma.line.count({ where: { tenantId, status: 'SUSPENDED' } }),
+      prisma.line.count({ where: { tenantId, status: 'TERMINATED' } }),
+      prisma.line.count({ where: { tenantId, status: 'FAILED' } }),
+      prisma.usageRecord.aggregate({
+        where: { line: { tenantId } },
+        _sum: { dataUsedMB: true },
+      }),
+    ]);
+
+    return res.json({
+      totalLines,
+      activeLines,
+      provisioningLines,
+      suspendedLines,
+      terminatedLines,
+      failedLines,
+      totalUsageGB: Number((((totalUsage._sum.dataUsedMB || 0) / 1024)).toFixed(1)),
+    });
+  } catch (error) {
+    logger.error('Failed to fetch metrics', { error });
+    return res.status(500).json({ error: 'Failed to fetch metrics' });
+  }
+});
+
+export default router;
diff --git a/apps/api/src/routes/lines.routes.ts b/apps/api/src/routes/lines.routes.ts
new file mode 100644
index 0000000..cc46fda
--- /dev/null
+++ b/apps/api/src/routes/lines.routes.ts
@@ -0,0 +1,419 @@
+import { Router, Request, Response } from 'express';
+import { z } from 'zod';
+import { prisma } from '../app';
+import { authMiddleware, requireRole, AuthenticatedRequest } from '../middleware/auth';
+import { logger } from '../lib/logger';
+
+const router = Router();
+router.use(authMiddleware);
+
+const createLineSchema = z.object({
+  planId: z.string().optional(),
+  quantity: z.coerce.number().int().min(1).max(25).default(1),
+});
+
+const allowedStatuses = new Set(['ACTIVE', 'PROVISIONING', 'SUSPENDED', 'TERMINATED', 'FAILED']);
+
+function generateMsisdn(): string {
+  const suffix = String(Math.floor(1000000000 + Math.random() * 9000000000));
+  return `+1${suffix}`;
+}
+
+function generateIccid(): string {
+  const digits = Array.from({ length: 18 }, () => Math.floor(Math.random() * 10)).join('');
+  return `89${digits}`;
+}
+
+function generateImsi(): string {
+  const digits = Array.from({ length: 9 }, () => Math.floor(Math.random() * 10)).join('');
+  return `310410${digits}`;
+}
+
+async function resolvePlan(tenantId: string, planId?: string) {
+  return planId
+    ? prisma.plan.findFirst({ where: { id: planId, OR: [{ tenantId }, { tenantId: null }], isActive: true } })
+    : prisma.plan.findFirst({
+        where: { OR: [{ tenantId }, { tenantId: null }], isActive: true },
+        orderBy: { createdAt: 'asc' },
+      });
+}
+
+async function attachBundle(lineId: string, tenantId: string, planId?: string) {
+  const plan = await resolvePlan(tenantId, planId);
+
+  if (!plan) return null;
+
+  return prisma.bundle.create({
+    data: {
+      planId: plan.id,
+      name: `${plan.name} Bundle`,
+      description: plan.description || undefined,
+      totalPrice: plan.price,
+      lineBundles: {
+        create: {
+          lineId,
+          activatedAt: new Date(),
+          expiresAt: new Date(Date.now() + plan.validityDays * 24 * 60 * 60 * 1000),
+        },
+      },
+    },
+    include: {
+      plan: true,
+      lineBundles: true,
+    },
+  });
+}
+
+router.get('/', async (req: Request, res: Response) => {
+  try {
+    const { tenantId } = (req as AuthenticatedRequest).user;
+    const page = Number(req.query.page as string) || 1;
+    const limit = Math.min(Number(req.query.limit as string) || 20, 100);
+    const status = (req.query.status as string | undefined)?.toUpperCase();
+    const search = (req.query.search as string | undefined)?.trim();
+
+    const where: Record<string, unknown> = { tenantId };
+
+    if (status && status !== 'ALL' && allowedStatuses.has(status)) {
+      where.status = status;
+    }
+
+    if (search) {
+      where.OR = [
+        { msisdn: { contains: search, mode: 'insensitive' } },
+        { iccid: { contains: search, mode: 'insensitive' } },
+        { imsi: { contains: search, mode: 'insensitive' } },
+      ];
+    }
+
+    const [lines, total] = await Promise.all([
+      prisma.line.findMany({
+        where,
+        include: {
+          esimProfile: true,
+          lineBundles: {
+            include: {
+              bundle: {
+                include: { plan: true },
+              },
+            },
+          },
+          usageRecords: {
+            orderBy: { recordedAt: 'desc' },
+            take: 1,
+          },
+        },
+        orderBy: { createdAt: 'desc' },
+        skip: (page - 1) * limit,
+        take: limit,
+      }),
+      prisma.line.count({ where }),
+    ]);
+
+    return res.json({
+      lines,
+      pagination: {
+        page,
+        limit,
+        total,
+        totalPages: Math.max(1, Math.ceil(total / limit)),
+      },
+    });
+  } catch (error) {
+    logger.error('Error fetching lines', { error });
+    return res.status(500).json({ error: 'Failed to fetch lines' });
+  }
+});
+
+router.get('/:id', async (req: Request, res: Response) => {
+  try {
+    const { tenantId } = (req as AuthenticatedRequest).user;
+    const { id } = req.params;
+
+    const line = await prisma.line.findFirst({
+      where: { id, tenantId },
+      include: {
+        esimProfile: true,
+        lineBundles: {
+          include: {
+            bundle: {
+              include: { plan: true, addon: true },
+            },
+          },
+        },
+        usageRecords: {
+          orderBy: { recordedAt: 'desc' },
+          take: 20,
+        },
+      },
+    });
+
+    if (!line) {
+      return res.status(404).json({ error: 'Line not found' });
+    }
+
+    return res.json(line);
+  } catch (error) {
+    logger.error('Error fetching line', { error });
+    return res.status(500).json({ error: 'Failed to fetch line' });
+  }
+});
+
+router.post('/', requireRole('ADMIN', 'USER'), async (req: Request, res: Response) => {
+  try {
+    const { tenantId, userId } = (req as AuthenticatedRequest).user;
+    const data = createLineSchema.parse(req.body);
+    const selectedPlan = await resolvePlan(tenantId, data.planId);
+
+    if (!selectedPlan) {
+      return res.status(400).json({ error: 'Selected plan is invalid or inactive' });
+    }
+
+    const created: Array<{ line: unknown; provisionJob: unknown }> = [];
+
+    for (let i = 0; i < data.quantity; i += 1) {
+      const provisionJob = await prisma.provisionJob.create({
+        data: {
+          tenantId,
+          status: 'QUEUED',
+          requestPayload: { planId: selectedPlan.id, quantity: 1 },
+          attempts: 0,
+          maxAttempts: 3,
+        },
+      });
+
+      const line = await prisma.line.create({
+        data: {
+          tenantId,
+          status: 'PROVISIONING',
+          provisionJobId: provisionJob.id,
+        },
+      });
+
+      await prisma.auditLog.create({
+        data: {
+          tenantId,
+          userId,
+          lineId: line.id,
+          action: 'LINE_PROVISION_INITIATED',
+          resource: 'Line',
+          details: { lineId: line.id, jobId: provisionJob.id, planId: selectedPlan.id },
+          ipAddress: req.ip,
+          userAgent: req.get('user-agent'),
+        },
+      });
+
+      setTimeout(() => {
+        void (async () => {
+          try {
+            const updatedLine = await prisma.line.update({
+              where: { id: line.id },
+              data: {
+                status: 'ACTIVE',
+                msisdn: generateMsisdn(),
+                iccid: generateIccid(),
+                imsi: generateImsi(),
+                activatedAt: new Date(),
+              },
+            });
+
+            await prisma.esimProfile.create({
+              data: {
+                lineId: line.id,
+                activationCode: `LPA:1$smdp.example.com$${Math.random().toString(36).slice(2, 10)}`,
+                smdpAddress: 'smdp.example.com',
+                qrCode: `QR_CODE_DATA_${line.id}`,
+                matchingId: Math.random().toString(36).slice(2, 10),
+              },
+            });
+
+            await attachBundle(updatedLine.id, tenantId, selectedPlan.id);
+
+            await prisma.provisionJob.update({
+              where: { id: provisionJob.id },
+              data: { status: 'COMPLETED', responseData: { lineId: updatedLine.id } },
+            });
+
+            await prisma.auditLog.create({
+              data: {
+                tenantId,
+                userId,
+                lineId: updatedLine.id,
+                action: 'LINE_PROVISION_COMPLETED',
+                resource: 'Line',
+                details: { lineId: updatedLine.id },
+                ipAddress: req.ip,
+                userAgent: req.get('user-agent'),
+              },
+            });
+          } catch (provisionError) {
+            logger.error('Provisioning simulation failed', { error: provisionError, lineId: line.id, provisionJobId: provisionJob.id });
+            await prisma.provisionJob
+              .update({
+                where: { id: provisionJob.id },
+                data: {
+                  status: 'FAILED',
+                  errorMessage: provisionError instanceof Error ? provisionError.message : 'Unknown provisioning error',
+                },
+              })
+              .catch(() => undefined);
+
+            await prisma.line
+              .update({
+                where: { id: line.id },
+                data: { status: 'FAILED' },
+              })
+              .catch(() => undefined);
+          }
+        })();
+      }, 2000 + i * 250);
+
+      created.push({ line, provisionJob });
+    }
+
+    logger.info('Line provisioning initiated', { count: created.length, tenantId });
+
+    return res.status(202).json({
+      lines: created.map((entry) => entry.line),
+      provisionJobs: created.map((entry) => entry.provisionJob),
+      message: created.length === 1 ? 'Provisioning initiated' : `${created.length} lines queued for provisioning`,
+    });
+  } catch (error) {
+    logger.error('Error creating line', { error });
+    return res.status(500).json({ error: 'Failed to create line' });
+  }
+});
+
+router.post('/:id/suspend', requireRole('ADMIN', 'USER'), async (req: Request, res: Response) => {
+  try {
+    const { tenantId, userId } = (req as AuthenticatedRequest).user;
+    const { id } = req.params;
+
+    const line = await prisma.line.findFirst({ where: { id, tenantId } });
+
+    if (!line) {
+      return res.status(404).json({ error: 'Line not found' });
+    }
+
+    if (line.status !== 'ACTIVE') {
+      return res.status(400).json({ error: 'Can only suspend active lines' });
+    }
+
+    const updatedLine = await prisma.line.update({
+      where: { id },
+      data: {
+        status: 'SUSPENDED',
+        suspendedAt: new Date(),
+      },
+    });
+
+    await prisma.auditLog.create({
+      data: {
+        tenantId,
+        userId,
+        lineId: id,
+        action: 'LINE_SUSPENDED',
+        resource: 'Line',
+        details: { previousStatus: 'ACTIVE' },
+        ipAddress: req.ip,
+        userAgent: req.get('user-agent'),
+      },
+    });
+
+    logger.info('Line suspended', { lineId: id, tenantId });
+    return res.json(updatedLine);
+  } catch (error) {
+    logger.error('Error suspending line', { error });
+    return res.status(500).json({ error: 'Failed to suspend line' });
+  }
+});
+
+router.post('/:id/resume', requireRole('ADMIN', 'USER'), async (req: Request, res: Response) => {
+  try {
+    const { tenantId, userId } = (req as AuthenticatedRequest).user;
+    const { id } = req.params;
+
+    const line = await prisma.line.findFirst({ where: { id, tenantId } });
+
+    if (!line) {
+      return res.status(404).json({ error: 'Line not found' });
+    }
+
+    if (line.status !== 'SUSPENDED') {
+      return res.status(400).json({ error: 'Can only resume suspended lines' });
+    }
+
+    const updatedLine = await prisma.line.update({
+      where: { id },
+      data: {
+        status: 'ACTIVE',
+        suspendedAt: null,
+      },
+    });
+
+    await prisma.auditLog.create({
+      data: {
+        tenantId,
+        userId,
+        lineId: id,
+        action: 'LINE_RESUMED',
+        resource: 'Line',
+        details: { previousStatus: 'SUSPENDED' },
+        ipAddress: req.ip,
+        userAgent: req.get('user-agent'),
+      },
+    });
+
+    logger.info('Line resumed', { lineId: id, tenantId });
+    return res.json(updatedLine);
+  } catch (error) {
+    logger.error('Error resuming line', { error });
+    return res.status(500).json({ error: 'Failed to resume line' });
+  }
+});
+
+router.delete('/:id', requireRole('ADMIN', 'USER'), async (req: Request, res: Response) => {
+  try {
+    const { tenantId, userId } = (req as AuthenticatedRequest).user;
+    const { id } = req.params;
+
+    const line = await prisma.line.findFirst({ where: { id, tenantId } });
+
+    if (!line) {
+      return res.status(404).json({ error: 'Line not found' });
+    }
+
+    if (line.status === 'TERMINATED') {
+      return res.status(400).json({ error: 'Line is already terminated' });
+    }
+
+    const updatedLine = await prisma.line.update({
+      where: { id },
+      data: {
+        status: 'TERMINATED',
+        terminatedAt: new Date(),
+      },
+    });
+
+    await prisma.auditLog.create({
+      data: {
+        tenantId,
+        userId,
+        lineId: id,
+        action: 'LINE_TERMINATED',
+        resource: 'Line',
+        details: { previousStatus: line.status },
+        ipAddress: req.ip,
+        userAgent: req.get('user-agent'),
+      },
+    });
+
+    logger.info('Line terminated', { lineId: id, tenantId });
+    return res.json(updatedLine);
+  } catch (error) {
+    logger.error('Error terminating line', { error });
+    return res.status(500).json({ error: 'Failed to terminate line' });
+  }
+});
+
+export default router;
