+import { Router, Request, Response } from 'express';
+import { prisma } from '../app';
+import { authMiddleware, AuthenticatedRequest } from '../middleware/auth';
+
+const router = Router();
+router.use(authMiddleware);
+
+router.get('/', async (req: Request, res: Response) => {
+  try {
+    const { tenantId } = (req as AuthenticatedRequest).user;
+    const page = Number(req.query.page as string) || 1;
+    const limit = Math.min(Number(req.query.limit as string) || 50, 100);
+    const action = (req.query.action as string | undefined)?.trim();
+    const resource = (req.query.resource as string | undefined)?.trim();
+    const actor = (req.query.actor as string | undefined)?.trim();
+
+    const where: Record<string, unknown> = { tenantId };
+
+    if (action) {
+      where.action = { contains: action, mode: 'insensitive' };
+    }
+
+    if (resource) {
+      where.resource = { contains: resource, mode: 'insensitive' };
+    }
+
+    if (actor) {
+      where.user = {
+        email: { contains: actor, mode: 'insensitive' },
+      };
+    }
+
+    const [logs, total] = await Promise.all([
+      prisma.auditLog.findMany({
+        where,
+        include: {
+          user: { select: { email: true, firstName: true, lastName: true } },
+          line: { select: { id: true, msisdn: true } },
+        },
+        orderBy: { createdAt: 'desc' },
+        skip: (page - 1) * limit,
+        take: limit,
+      }),
+      prisma.auditLog.count({ where }),
+    ]);
+
+    return res.json({
+      logs,
+      pagination: {
+        page,
+        limit,
+        total,
+        totalPages: Math.max(1, Math.ceil(total / limit)),
+      },
+    });
+  } catch (error) {
+    return res.status(500).json({ error: 'Failed to fetch audit logs' });
+  }
+});
+
+export default router;
diff --git a/apps/api/src/routes/auth.routes.ts b/apps/api/src/routes/auth.routes.ts
new file mode 100644
index 0000000..17a325b
--- /dev/null
+++ b/apps/api/src/routes/auth.routes.ts
@@ -0,0 +1,209 @@
+import { Router, Request, Response } from 'express';
+import bcrypt from 'bcryptjs';
+import jwt from 'jsonwebtoken';
+import { z } from 'zod';
+import { prisma } from '../app';
+import { logger } from '../lib/logger';
+
+const router = Router();
+
+const loginSchema = z.object({
+  email: z.string().email(),
+  password: z.string().min(6),
+});
+
+const registerSchema = z.object({
+  email: z.string().email(),
+  password: z.string().min(6),
+  firstName: z.string().optional(),
+  lastName: z.string().optional(),
+  tenantName: z.string().optional(),
+});
+
+function generateTokens(userId: string, tenantId: string, role: string) {
+  const payload = { userId, tenantId, role };
+  const accessToken = jwt.sign(payload, process.env.JWT_SECRET!, { expiresIn: '15m' });
+  const refreshToken = jwt.sign(payload, process.env.REFRESH_TOKEN_SECRET!, { expiresIn: '7d' });
+  return { accessToken, refreshToken };
+}
+
+function getCookieOptions(maxAge: number) {
+  const secure = (process.env.COOKIE_SECURE || '').toLowerCase() === 'true' || process.env.NODE_ENV === 'production';
+  const sameSite = (process.env.COOKIE_SAMESITE || 'lax') as 'lax' | 'strict' | 'none';
+  return {
+    httpOnly: true,
+    secure,
+    sameSite,
+    maxAge,
+  };
+}
+
+router.post('/login', async (req: Request, res: Response) => {
+  try {
+    const { email, password } = loginSchema.parse(req.body);
+
+    const user = await prisma.user.findUnique({
+      where: { email },
+      include: { tenant: true },
+    });
+
+    if (!user || !user.isActive) {
+      return res.status(401).json({ error: 'Invalid credentials' });
+    }
+
+    const isValidPassword = await bcrypt.compare(password, user.passwordHash);
+    if (!isValidPassword) {
+      return res.status(401).json({ error: 'Invalid credentials' });
+    }
+
+    const { accessToken, refreshToken } = generateTokens(user.id, user.tenantId, user.role);
+
+    res.cookie('accessToken', accessToken, getCookieOptions(15 * 60 * 1000));
+
+    res.cookie('refreshToken', refreshToken, getCookieOptions(7 * 24 * 60 * 60 * 1000));
+
+    logger.info('User logged in', { email });
+
+    return res.json({
+      user: {
+        id: user.id,
+        email: user.email,
+        firstName: user.firstName,
+        lastName: user.lastName,
+        role: user.role,
+        tenant: user.tenant.name,
+      },
+      accessToken,
+    });
+  } catch (error) {
+    logger.error('Login error', { error });
+    if (error instanceof z.ZodError) {
+      return res.status(400).json({ error: 'Validation failed', details: error.flatten() });
+    }
+    return res.status(400).json({ error: 'Login failed' });
+  }
+});
+
+router.post('/register', async (req: Request, res: Response) => {
+  try {
+    const data = registerSchema.parse(req.body);
+
+    const existingUser = await prisma.user.findUnique({ where: { email: data.email } });
+    if (existingUser) {
+      return res.status(409).json({ error: 'Email already registered' });
+    }
+
+    const passwordHash = await bcrypt.hash(data.password, 10);
+
+    const result = await prisma.$transaction(async (tx: any) => {
+      const tenant = await tx.tenant.create({
+        data: {
+          name: data.tenantName || `${data.email}'s Organization`,
+        },
+      });
+
+      const user = await tx.user.create({
+        data: {
+          email: data.email,
+          passwordHash,
+          firstName: data.firstName,
+          lastName: data.lastName,
+          tenantId: tenant.id,
+          role: 'ADMIN',
+        },
+      });
+
+      return { user, tenant };
+    });
+
+    const { accessToken, refreshToken } = generateTokens(result.user.id, result.tenant.id, result.user.role);
+
+    res.cookie('accessToken', accessToken, getCookieOptions(15 * 60 * 1000));
+
+    res.cookie('refreshToken', refreshToken, getCookieOptions(7 * 24 * 60 * 60 * 1000));
+
+    logger.info('New user registered', { email: data.email });
+
+    return res.status(201).json({
+      user: {
+        id: result.user.id,
+        email: result.user.email,
+        firstName: result.user.firstName,
+        lastName: result.user.lastName,
+        role: result.user.role,
+        tenant: result.tenant.name,
+      },
+      accessToken,
+    });
+  } catch (error) {
+    logger.error('Registration error', { error });
+    if (error instanceof z.ZodError) {
+      return res.status(400).json({ error: 'Validation failed', details: error.flatten() });
+    }
+    return res.status(400).json({ error: 'Registration failed' });
+  }
+});
+
+router.post('/refresh', async (req: Request, res: Response) => {
+  try {
+    const refreshToken = req.cookies.refreshToken;
+
+    if (!refreshToken) {
+      return res.status(401).json({ error: 'Refresh token required' });
+    }
+
+    const decoded = jwt.verify(refreshToken, process.env.REFRESH_TOKEN_SECRET!) as { userId: string; tenantId: string; role?: string };
+    const tokens = generateTokens(decoded.userId, decoded.tenantId, decoded.role || 'VIEWER');
+
+    res.cookie('accessToken', tokens.accessToken, getCookieOptions(15 * 60 * 1000));
+    res.cookie('refreshToken', tokens.refreshToken, getCookieOptions(7 * 24 * 60 * 60 * 1000));
+
+    return res.json({ accessToken: tokens.accessToken });
+  } catch (error) {
+    logger.warn('Refresh token rejected', { error });
+    return res.status(401).json({ error: 'Invalid refresh token' });
+  }
+});
+
+router.post('/logout', (_req: Request, res: Response) => {
+  res.clearCookie('accessToken', getCookieOptions(0));
+  res.clearCookie('refreshToken', getCookieOptions(0));
+  return res.json({ message: 'Logged out successfully' });
+});
+
+router.get('/me', async (req: Request, res: Response) => {
+  try {
+    const token = req.cookies.accessToken || req.headers.authorization?.split(' ')[1];
+
+    if (!token) {
+      return res.status(401).json({ error: 'Not authenticated' });
+    }
+
+    const decoded = jwt.verify(token, process.env.JWT_SECRET!) as { userId: string };
+
+    const user = await prisma.user.findUnique({
+      where: { id: decoded.userId },
+      include: { tenant: true },
+    });
+
+    if (!user || !user.isActive) {
+      return res.status(404).json({ error: 'User not found' });
+    }
+
+    return res.json({
+      user: {
+        id: user.id,
+        email: user.email,
+        firstName: user.firstName,
+        lastName: user.lastName,
+        role: user.role,
+        tenant: user.tenant.name,
+      },
+    });
+  } catch (error) {
+    logger.warn('Failed to resolve current user', { error });
+    return res.status(401).json({ error: 'Invalid token' });
+  }
+});
+
+export default router;
