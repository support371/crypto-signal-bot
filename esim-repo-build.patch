+++ b/apps/api/prisma/seed.ts
@@ -0,0 +1,174 @@
+import { PrismaClient } from '@prisma/client';
+import bcrypt from 'bcryptjs';
+
+const prisma = new PrismaClient();
+
+async function main() {
+  console.log('🌱 Seeding database...');
+
+  const existingTenant = await prisma.tenant.findUnique({ where: { id: 'demo-tenant' } });
+
+  if (existingTenant) {
+    await prisma.plan.deleteMany({ where: { tenantId: existingTenant.id } });
+    await prisma.provisionJob.deleteMany({ where: { tenantId: existingTenant.id } });
+    await prisma.tenant.delete({ where: { id: existingTenant.id } });
+    console.log('♻️ Reset existing demo tenant data');
+  }
+
+  const tenant = await prisma.tenant.create({
+    data: {
+      id: 'demo-tenant',
+      name: 'Demo Corporation',
+    },
+  });
+
+  const passwordHash = await bcrypt.hash(process.env.ADMIN_PASSWORD || 'SecurePassword123!', 10);
+
+  const admin = await prisma.user.create({
+    data: {
+      email: 'admin@example.com',
+      passwordHash,
+      firstName: 'Admin',
+      lastName: 'User',
+      role: 'ADMIN',
+      tenantId: tenant.id,
+    },
+  });
+
+  const plans = await Promise.all([
+    prisma.plan.create({
+      data: {
+        tenantId: tenant.id,
+        name: 'Global 5GB',
+        description: '5GB data plan for global coverage',
+        dataAmountMB: 5120,
+        validityDays: 30,
+        price: 29.99,
+        currency: 'USD',
+        isGlobal: true,
+        isActive: true,
+      },
+    }),
+    prisma.plan.create({
+      data: {
+        tenantId: tenant.id,
+        name: 'US Unlimited',
+        description: 'Unlimited data in United States',
+        dataAmountMB: 999999,
+        validityDays: 30,
+        price: 49.99,
+        currency: 'USD',
+        isActive: true,
+      },
+    }),
+    prisma.plan.create({
+      data: {
+        tenantId: tenant.id,
+        name: 'EU 10GB',
+        description: '10GB data plan for Europe',
+        dataAmountMB: 10240,
+        validityDays: 30,
+        price: 39.99,
+        currency: 'USD',
+        isActive: true,
+      },
+    }),
+  ]);
+
+  const lineStatuses = ['ACTIVE', 'PROVISIONING', 'SUSPENDED', 'TERMINATED', 'FAILED', 'ACTIVE'] as const;
+  const lines = [];
+
+  for (let i = 0; i < 18; i += 1) {
+    const status = lineStatuses[i % lineStatuses.length];
+    const createdAt = new Date(Date.now() - i * 6 * 24 * 60 * 60 * 1000);
+    const msisdn = status === 'PROVISIONING' ? null : `+1${String(2025550000 + i).padStart(10, '0')}`;
+    const iccid = status === 'PROVISIONING' ? null : `890123456789012345${String(i).padStart(2, '0')}`;
+
+    const line = await prisma.line.create({
+      data: {
+        tenantId: tenant.id,
+        msisdn,
+        iccid,
+        imsi: msisdn ? `310410${String(i).padStart(9, '0')}` : null,
+        status,
+        activatedAt: status === 'ACTIVE' ? new Date(createdAt.getTime() + 60 * 60 * 1000) : null,
+        suspendedAt: status === 'SUSPENDED' ? new Date(createdAt.getTime() + 2 * 60 * 60 * 1000) : null,
+        terminatedAt: status === 'TERMINATED' ? new Date(createdAt.getTime() + 3 * 60 * 60 * 1000) : null,
+        createdAt,
+      },
+    });
+
+    lines.push(line);
+
+    if (status !== 'PROVISIONING') {
+      await prisma.esimProfile.create({
+        data: {
+          lineId: line.id,
+          activationCode: `LPA:1$smdp.example.com$matching-id-${i}`,
+          smdpAddress: 'smdp.example.com',
+          qrCode: `QR_CODE_DATA_${line.id}`,
+          matchingId: `matching-${i}`,
+          confirmationCode: String(100000 + i),
+        },
+      });
+
+      await prisma.bundle.create({
+        data: {
+          planId: plans[i % plans.length].id,
+          name: `${plans[i % plans.length].name} Bundle`,
+          totalPrice: plans[i % plans.length].price,
+          lineBundles: {
+            create: {
+              lineId: line.id,
+              activatedAt: createdAt,
+              expiresAt: new Date(createdAt.getTime() + 30 * 24 * 60 * 60 * 1000),
+            },
+          },
+        },
+      });
+
+      if (status === 'ACTIVE') {
+        const usageCount = (i % 4) + 1;
+        for (let j = 0; j < usageCount; j += 1) {
+          await prisma.usageRecord.create({
+            data: {
+              lineId: line.id,
+              dataUsedMB: 256 + i * 32 + j * 128,
+              recordedAt: new Date(createdAt.getTime() + j * 12 * 60 * 60 * 1000),
+            },
+          });
+        }
+      }
+    }
+  }
+
+  for (let i = 0; i < Math.min(lines.length, 12); i += 1) {
+    await prisma.auditLog.create({
+      data: {
+        tenantId: tenant.id,
+        userId: admin.id,
+        lineId: lines[i].id,
+        action: ['LINE_CREATED', 'LINE_ACTIVATED', 'LINE_SUSPENDED', 'LINE_RESUMED', 'LINE_TERMINATED', 'LINE_PROVISION_INITIATED'][i % 6],
+        resource: 'Line',
+        details: { lineId: lines[i].id },
+        ipAddress: '127.0.0.1',
+        userAgent: 'seed-script',
+        createdAt: new Date(Date.now() - i * 4 * 60 * 60 * 1000),
+      },
+    });
+  }
+
+  console.log('🎉 Database seeding completed!');
+  console.log(`Admin Email: admin@example.com`);
+  console.log(`Password: ${process.env.ADMIN_PASSWORD || 'SecurePassword123!'}`);
+  console.log(`Demo Data: ${lines.length} eSIM lines, ${plans.length} plans, audit logs, and usage records`);
+}
+
+main()
+  .catch((e) => {
+    console.error('❌ Seeding failed:', e);
+    process.exit(1);
+  })
+  .finally(async () => {
+    await prisma.$disconnect();
+  });
