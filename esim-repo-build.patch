+import type { Metadata } from 'next'
+import '../styles/globals.css'
+import { Toaster } from 'react-hot-toast'
+
+export const metadata: Metadata = {
+  title: 'eSIM Platform - Enterprise eSIM Management',
+  description: 'Production-grade eSIM management platform with real-time provisioning, monitoring, and analytics',
+}
+
+export default function RootLayout({ children }: { children: React.ReactNode }) {
+  return (
+    <html lang="en">
+      <body className="antialiased min-h-screen bg-dark-950 text-dark-50 font-sans">
+        <Toaster
+          position="top-right"
+          toastOptions={{
+            duration: 4000,
+            style: {
