diff --git a/apps/api/prisma/schema.prisma b/apps/api/prisma/schema.prisma
new file mode 100644
index 0000000..adc51ff
--- /dev/null
+++ b/apps/api/prisma/schema.prisma
@@ -0,0 +1,304 @@
+// Prisma schema for eSIM Platform
+generator client {
+  provider = "prisma-client-js"
+}
+
+datasource db {
+  provider = "postgresql"
+  url      = env("DATABASE_URL")
+}
+
+model Tenant {
+  id        String   @id @default(cuid())
+  name      String
+  createdAt DateTime @default(now())
+  updatedAt DateTime @updatedAt
+
+  users    User[]
+  lines    Line[]
+  plans    Plan[]
+  apiKeys  ApiKey[]
+  auditLogs AuditLog[]
+
+  @@map("tenants")
+}
+
+model User {
+  id           String   @id @default(cuid())
+  tenantId     String
+  email        String   @unique
+  passwordHash String
+  firstName    String?
+  lastName     String?
+  role         UserRole @default(USER)
+  isActive     Boolean  @default(true)
+  createdAt    DateTime @default(now())
+  updatedAt    DateTime @updatedAt
+
+  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
+  auditLogs AuditLog[]
+
+  @@index([tenantId])
+  @@index([email])
+  @@map("users")
+}
+
+enum UserRole {
+  ADMIN
+  USER
+  VIEWER
+}
+
+model Line {
+  id              String     @id @default(cuid())
+  tenantId        String
+  msisdn          String?    @unique
+  iccid           String?    @unique
+  imsi            String?
+  status          LineStatus @default(PROVISIONING)
+  telnyxLineId    String?    @unique
+  provisionJobId  String?    @unique
+  activatedAt     DateTime?
+  suspendedAt     DateTime?
+  terminatedAt    DateTime?
+  createdAt       DateTime   @default(now())
+  updatedAt       DateTime   @updatedAt
+
+  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
+  esimProfile    EsimProfile?
+  provisionJob   ProvisionJob?   @relation(fields: [provisionJobId], references: [id])
+  lineBundles    LineBundle[]
+  lineAddons     LineAddon[]
+  usageRecords   UsageRecord[]
+  auditLogs      AuditLog[]
+
+  @@index([tenantId])
+  @@index([status])
+  @@index([createdAt])
+  @@map("lines")
+}
+
+enum LineStatus {
+  PROVISIONING
+  ACTIVE
+  SUSPENDED
+  TERMINATED
+  FAILED
+}
+
+model EsimProfile {
+  id              String   @id @default(cuid())
+  lineId          String   @unique
+  activationCode  String
+  smdpAddress     String
+  qrCode          String   @db.Text
+  matchingId      String?
+  confirmationCode String?
+  createdAt       DateTime @default(now())
+  updatedAt       DateTime @updatedAt
+
+  line Line @relation(fields: [lineId], references: [id], onDelete: Cascade)
+
+  @@map("esim_profiles")
+}
+
+model ProvisionJob {
+  id             String          @id @default(cuid())
+  tenantId       String
+  status         ProvisionStatus @default(QUEUED)
+  telnyxOrderId  String?
+  requestPayload Json
+  responseData   Json?
+  errorMessage   String?
+  attempts       Int             @default(0)
+  maxAttempts    Int             @default(3)
+  createdAt      DateTime        @default(now())
+  updatedAt      DateTime        @updatedAt
+
+  lines Line[]
+
+  @@index([tenantId])
+  @@index([status])
+  @@index([createdAt])
+  @@map("provision_jobs")
+}
+
+enum ProvisionStatus {
+  QUEUED
+  PROCESSING
+  COMPLETED
+  FAILED
+}
+
+model Plan {
+  id           String   @id @default(cuid())
+  tenantId     String?
+  name         String
+  description  String?
+  dataAmountMB Int
+  validityDays Int
+  price        Decimal  @db.Decimal(10, 2)
+  currency     String   @default("USD")
+  isGlobal     Boolean  @default(false)
+  isActive     Boolean  @default(true)
+  createdAt    DateTime @default(now())
+  updatedAt    DateTime @updatedAt
+
+  tenant  Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
+  bundles Bundle[]
+
+  @@index([tenantId])
+  @@index([isActive])
+  @@map("plans")
+}
+
+model Addon {
+  id          String   @id @default(cuid())
+  name        String
+  description String?
+  price       Decimal  @db.Decimal(10, 2)
+  currency    String   @default("USD")
+  isActive    Boolean  @default(true)
+  createdAt   DateTime @default(now())
+  updatedAt   DateTime @updatedAt
+
+  bundles    Bundle[]
+  lineAddons LineAddon[]
+
+  @@map("addons")
+}
+
+model Bundle {
+  id          String   @id @default(cuid())
+  planId      String
+  addonId     String?
+  name        String
+  description String?
+  totalPrice  Decimal  @db.Decimal(10, 2)
+  isActive    Boolean  @default(true)
+  createdAt   DateTime @default(now())
+  updatedAt   DateTime @updatedAt
+
+  plan        Plan         @relation(fields: [planId], references: [id], onDelete: Cascade)
+  addon       Addon?       @relation(fields: [addonId], references: [id], onDelete: SetNull)
+  lineBundles LineBundle[]
+
+  @@index([planId])
+  @@map("bundles")
+}
+
+model LineBundle {
+  id          String    @id @default(cuid())
+  lineId      String
+  bundleId    String
+  activatedAt DateTime  @default(now())
+  expiresAt   DateTime?
+  createdAt   DateTime  @default(now())
+  updatedAt   DateTime  @updatedAt
+
+  line   Line   @relation(fields: [lineId], references: [id], onDelete: Cascade)
+  bundle Bundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
+
+  @@index([lineId])
+  @@index([bundleId])
+  @@map("line_bundles")
+}
+
+model LineAddon {
+  id          String    @id @default(cuid())
+  lineId      String
+  addonId     String
+  activatedAt DateTime  @default(now())
+  expiresAt   DateTime?
+  createdAt   DateTime  @default(now())
+  updatedAt   DateTime  @updatedAt
+
+  line  Line  @relation(fields: [lineId], references: [id], onDelete: Cascade)
+  addon Addon @relation(fields: [addonId], references: [id], onDelete: Cascade)
+
+  @@index([lineId])
+  @@index([addonId])
+  @@map("line_addons")
+}
+
+model UsageRecord {
+  id           String   @id @default(cuid())
+  lineId       String
+  dataUsedMB   Int
+  recordedAt   DateTime
+  sessionStart DateTime?
+  sessionEnd   DateTime?
+  createdAt    DateTime @default(now())
+  updatedAt    DateTime @updatedAt
+
+  line Line @relation(fields: [lineId], references: [id], onDelete: Cascade)
+
+  @@index([lineId])
+  @@index([recordedAt])
+  @@map("usage_records")
+}
+
+model Webhook {
+  id           String        @id @default(cuid())
+  eventType    String
+  payload      Json
+  signature    String?
+  status       WebhookStatus @default(PENDING)
+  processedAt  DateTime?
+  errorMessage String?
+  createdAt    DateTime      @default(now())
+  updatedAt    DateTime      @updatedAt
+
+  @@index([eventType])
+  @@index([status])
+  @@index([createdAt])
+  @@map("webhooks")
+}
+
+enum WebhookStatus {
+  PENDING
+  PROCESSED
+  FAILED
+}
+
+model AuditLog {
+  id         String   @id @default(cuid())
+  tenantId   String
+  userId     String?
+  lineId     String?
+  action     String
+  resource   String
+  details    Json?
+  ipAddress  String?
+  userAgent  String?
+  createdAt  DateTime @default(now())
+
+  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
+  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
+  line   Line?  @relation(fields: [lineId], references: [id], onDelete: SetNull)
+
+  @@index([tenantId])
+  @@index([userId])
+  @@index([lineId])
+  @@index([action])
+  @@index([createdAt])
+  @@map("audit_logs")
+}
+
+model ApiKey {
+  id          String   @id @default(cuid())
+  tenantId    String
+  name        String
+  key         String   @unique
+  lastUsedAt  DateTime?
+  expiresAt   DateTime?
+  isActive    Boolean  @default(true)
+  createdAt   DateTime @default(now())
+  updatedAt   DateTime @updatedAt
+
+  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
+
+  @@index([tenantId])
+  @@index([key])
+  @@map("api_keys")
+}
