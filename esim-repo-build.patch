+import toast from 'react-hot-toast'
+import { useAuthStore } from '@/lib/auth-store'
+import { GlobeIcon, LogoutIcon } from '@/components/icons'
+
+const navItems = [
+  { href: '/', label: 'Dashboard' },
+  { href: '/lines', label: 'Lines' },
+  { href: '/analytics', label: 'Analytics' },
+  { href: '/audit', label: 'Audit' },
+]
+
+export function AppShell({ title, subtitle, children, actions }: { title: string; subtitle?: string; children: React.ReactNode; actions?: React.ReactNode }) {
+  const pathname = usePathname()
+  const router = useRouter()
+  const { user, logout, checkAuth, hasCheckedAuth, isLoading } = useAuthStore()
+  useEffect(() => { if (!hasCheckedAuth) void checkAuth() }, [checkAuth, hasCheckedAuth])
+  useEffect(() => { if (hasCheckedAuth && !isLoading && !user) router.replace('/login') }, [hasCheckedAuth, isLoading, router, user])
+  const handleLogout = async () => { try { await logout(); router.push('/login') } catch { toast.error('Logout failed') } }
+  if (!hasCheckedAuth || (isLoading && !user)) return <div className="min-h-screen bg-gradient-to-br from-dark-950 via-dark-900 to-dark-950 flex items-center justify-center"><div className="w-14 h-14 border-4 border-primary-600 border-t-transparent rounded-full animate-spin" /></div>
+  return <div className="min-h-screen bg-gradient-to-br from-dark-950 via-dark-900 to-dark-950"><nav className="border-b border-dark-800/50 backdrop-blur-xl bg-dark-950/50 sticky top-0 z-50"><div className="max-w-7xl mx-auto px-6 py-4"><div className="flex items-center justify-between gap-4"><Link href="/" className="flex items-center gap-3"><div className="w-10 h-10 bg-gradient-to-br from-primary-500 to-accent-500 rounded-lg flex items-center justify-center"><GlobeIcon className="w-6 h-6 text-white" /></div><div><h1 className="text-xl font-bold gradient-text">eSIM Platform</h1><p className="text-xs text-dark-400">Enterprise Management</p></div></Link><div className="flex items-center gap-6"><div className="hidden md:flex items-center gap-5">{navItems.map((item)=><Link key={item.href} href={item.href} className={clsx('text-sm transition-colors', pathname===item.href ? 'text-dark-50' : 'text-dark-300 hover:text-dark-100')}>{item.label}</Link>)}</div>{user ? <div className="flex items-center gap-3 pl-4 border-l border-dark-800"><div className="text-right hidden sm:block"><p className="text-sm font-medium">{user.firstName || user.email}</p><div className="flex items-center justify-end gap-2"><p className="text-xs text-dark-500">{user.tenant}</p><span className="text-[10px] uppercase tracking-wide px-2 py-0.5 rounded-full border border-dark-700 text-dark-300">{user.role}</span></div></div><button onClick={() => void handleLogout()} className="p-2 text-dark-400 hover:text-red-400 transition-colors" title="Logout" aria-label="Logout"><LogoutIcon className="w-5 h-5" /></button></div> : null}</div></div></div></nav><main className="max-w-7xl mx-auto px-6 py-8"><div className="flex flex-col gap-4 md:flex-row md:items-end md:justify-between mb-8"><div><h2 className="text-3xl font-bold mb-2">{title}</h2>{subtitle ? <p className="text-dark-400">{subtitle}</p> : null}</div>{actions ? <div className="flex flex-wrap items-center gap-3">{actions}</div> : null}</div>{children}</main></div>
