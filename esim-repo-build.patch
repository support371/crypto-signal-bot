@@ -0,0 +1,135 @@
+import crypto from 'crypto';
+import { Router, Request, Response } from 'express';
+import { prisma } from '../app';
+import { logger } from '../lib/logger';
+
+const router = Router();
+
+function safeCompare(a: string, b: string) {
+  const aBuffer = Buffer.from(a);
+  const bBuffer = Buffer.from(b);
+
+  if (aBuffer.length !== bBuffer.length) {
+    return false;
+  }
+
+  return crypto.timingSafeEqual(aBuffer, bBuffer);
+}
+
+function normalizeSignatures(headerValue?: string | string[]) {
+  if (!headerValue) return [];
+  const combined = Array.isArray(headerValue) ? headerValue.join(',') : headerValue;
+
+  return combined
+    .split(',')
+    .map((entry) => entry.trim())
+    .flatMap((entry) => {
+      if (entry.includes('=')) {
+        return entry
+          .split(';')
+          .map((part) => part.trim())
+          .filter(Boolean)
+          .map((part) => part.split('=').slice(1).join('=').trim())
+          .filter(Boolean);
+      }
+
+      return entry ? [entry] : [];
+    });
+}
+
+function getTimestamp(req: Request) {
+  return (
+    (req.headers['telnyx-timestamp'] as string | undefined) ||
+    (req.headers['x-webhook-timestamp'] as string | undefined) ||
+    (req.headers['x-signature-timestamp'] as string | undefined)
+  );
+}
+
+function verifyWebhookSignature(req: Request) {
+  const secret = process.env.WEBHOOK_SECRET;
+  const rawBody = (req as Request & { rawBody?: string }).rawBody || JSON.stringify(req.body || {});
+  const signatureHeaders = [
+    req.headers['x-webhook-signature'],
+    req.headers['x-signature'],
+    req.headers['telnyx-signature-ed25519'],
+  ];
+
+  if (!secret) {
+    logger.warn('Webhook secret not configured; skipping signature verification');
+    return { valid: true, reason: 'secret_not_configured' };
+  }
+
+  const timestamp = getTimestamp(req);
+  const tolerance = Number(process.env.WEBHOOK_TOLERANCE_SECONDS || 300);
+
+  if (timestamp) {
+    const ageSeconds = Math.abs(Date.now() - Number(timestamp) * 1000) / 1000;
+    if (Number.isFinite(ageSeconds) && ageSeconds > tolerance) {
+      return { valid: false, reason: 'timestamp_out_of_range' };
+    }
+  }
+
+  const expected = crypto
+    .createHmac('sha256', secret)
+    .update(timestamp ? `${timestamp}.${rawBody}` : rawBody)
+    .digest('hex');
+
+  const signatures = signatureHeaders.flatMap((header) => normalizeSignatures(header));
+
+  if (signatures.length === 0) {
+    return { valid: false, reason: 'signature_missing' };
+  }
+
+  const matched = signatures.some((signature) => safeCompare(signature, expected));
+  return { valid: matched, reason: matched ? 'ok' : 'signature_mismatch' };
+}
+
+router.post('/telnyx', async (req: Request, res: Response) => {
+  const verification = verifyWebhookSignature(req);
+  const eventType = req.body?.data?.event_type || req.body?.data?.eventType || 'unknown';
+
+  if (!verification.valid) {
+    logger.warn('Webhook rejected', {
+      eventType,
+      reason: verification.reason,
+      requestId: req.headers['x-request-id'],
+    });
+
+    await prisma.webhook
+      .create({
+        data: {
+          eventType,
+          payload: req.body,
+          signature: (req.headers['x-webhook-signature'] as string | undefined) || (req.headers['telnyx-signature-ed25519'] as string | undefined) || null,
+          status: 'FAILED',
+          errorMessage: verification.reason,
+        },
+      })
+      .catch(() => undefined);
+
+    return res.status(401).json({ error: 'Invalid webhook signature' });
+  }
+
+  try {
+    const webhook = await prisma.webhook.create({
+      data: {
+        eventType,
+        payload: req.body,
+        signature:
+          (req.headers['x-webhook-signature'] as string | undefined) ||
+          (req.headers['telnyx-signature-ed25519'] as string | undefined) ||
+          null,
+        status: 'PROCESSED',
+        processedAt: new Date(),
+      },
+    });
+
+    logger.info('Webhook received', { eventType: webhook.eventType, webhookId: webhook.id, verification: verification.reason });
+    return res.status(200).json({ received: true, webhookId: webhook.id });
+  } catch (error) {
+    logger.error('Webhook processing error', { error, eventType, verification: verification.reason });
+    return res.status(500).json({ error: 'Webhook processing failed' });
+  }
+});
+
+export default router;
