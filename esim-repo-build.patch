+'use client'
+
+import { useEffect, useMemo, useState } from 'react'
+import { useRouter } from 'next/navigation'
+import Link from 'next/link'
+import toast from 'react-hot-toast'
+import { AppShell } from '@/components/app-shell'
+import { ArrowLeftIcon, LayersIcon, PlusIcon, RadioTowerIcon, ShieldAlertIcon } from '@/components/icons'
+import { api } from '@/lib/api'
+import { useAuthStore } from '@/lib/auth-store'
+import type { Plan } from '@/lib/types'
+
+function formatPlan(plan: Plan) { const dataLabel = plan.dataAmountMB >= 999999 ? 'Unlimited' : `${(plan.dataAmountMB / 1024).toFixed(0)} GB`; return `${plan.name} - ${dataLabel} - ${plan.validityDays} days` }
+
+export default function NewLinePage() {
+  const router = useRouter()
+  const { user } = useAuthStore()
+  const [plans, setPlans] = useState<Plan[]>([])
+  const [planId, setPlanId] = useState<string>('')
+  const [quantity, setQuantity] = useState(1)
+  const [isLoadingPlans, setIsLoadingPlans] = useState(true)
+  const [isSubmitting, setIsSubmitting] = useState(false)
+  useEffect(() => { const loadPlans = async () => { try { const response = await api.plans.list(); const availablePlans = response.plans || []; setPlans(availablePlans); setPlanId(availablePlans[0]?.id || '') } catch (error: any) { toast.error(error.response?.data?.error || 'Failed to load plans') } finally { setIsLoadingPlans(false) } }; void loadPlans() }, [])
+  const selectedPlan = useMemo(() => plans.find((plan) => plan.id === planId) || null, [planId, plans])
+  const isReadOnly = user?.role === 'VIEWER'
+  const handleSubmit = async (e: React.FormEvent) => { e.preventDefault(); if (isReadOnly) { toast.error('Viewer access cannot provision new lines'); return } try { setIsSubmitting(true); await api.lines.create({ quantity, planId: planId || undefined }); router.push('/lines') } catch (error: any) { toast.error(error.response?.data?.error || 'Failed to queue provisioning') } finally { setIsSubmitting(false) } }
+  return <AppShell title="Provision New Line" subtitle="Queue one or more lines for asynchronous provisioning."><div className="max-w-2xl glass-card p-8 rounded-2xl"><Link href="/lines" className="inline-flex items-center gap-2 text-dark-400 hover:text-dark-200 mb-6 transition-colors"><ArrowLeftIcon className="w-4 h-4" />Back to lines</Link>{isReadOnly ? <div className="mb-6 rounded-xl border border-amber-500/30 bg-amber-500/10 p-4 flex items-start gap-3 text-sm text-amber-200"><ShieldAlertIcon className="w-5 h-5 mt-0.5" /><div><p className="font-semibold">Read-only access</p><p className="text-amber-100/80 mt-1">Your current role can inspect inventory but cannot submit provisioning jobs.</p></div></div> : null}<form onSubmit={handleSubmit} className="space-y-6"><div><label className="block text-sm font-medium mb-2">Plan</label><div className="relative"><RadioTowerIcon className="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-dark-500" /><select value={planId} onChange={(e) => setPlanId(e.target.value)} className="input pl-12" disabled={isLoadingPlans || plans.length === 0 || isReadOnly}>{plans.map((plan) => <option key={plan.id} value={plan.id}>{formatPlan(plan)}</option>)}</select></div>{selectedPlan ? <p className="text-sm text-dark-400 mt-2">{selectedPlan.description || 'Provision lines against the selected rate plan.'}</p> : <p className="text-sm text-dark-400 mt-2">Loading available rate plans...</p>}</div><div><label className="block text-sm font-medium mb-2">Quantity</label><div className="relative"><LayersIcon className="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-dark-500" /><input type="number" min={1} max={25} value={quantity} onChange={(e) => setQuantity(Math.min(25, Math.max(1, Number(e.target.value) || 1)))} className="input pl-12" disabled={isReadOnly} /></div><p className="text-sm text-dark-400 mt-2">Batch queueing is enabled for up to 25 lines per request.</p></div><button type="submit" disabled={isSubmitting || isLoadingPlans || plans.length === 0 || isReadOnly} className="btn-primary flex items-center gap-2 disabled:opacity-50"><PlusIcon className="w-4 h-4" />{isSubmitting ? 'Queueing...' : 'Queue provisioning'}</button></form></div></AppShell>
+}
