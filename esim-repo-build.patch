+++ b/apps/web/src/lib/api.ts
@@ -0,0 +1,157 @@
+import axios, { AxiosError, AxiosInstance, InternalAxiosRequestConfig } from 'axios'
+import toast from 'react-hot-toast'
+
+const API_URL = process.env.NEXT_PUBLIC_API_URL || 'http://localhost:3001'
+
+type RetriableConfig = InternalAxiosRequestConfig & {
+  _retry?: boolean
+}
+
+class APIClient {
+  private client: AxiosInstance
+
+  constructor() {
+    this.client = axios.create({
+      baseURL: `${API_URL}/api`,
+      withCredentials: true,
+      headers: {
+        'Content-Type': 'application/json',
+      },
+    })
+
+    this.client.interceptors.response.use(
+      (response) => response,
+      async (error: AxiosError<{ error?: string }>) => {
+        const config = error.config as RetriableConfig | undefined
+        const isAuthRoute = config?.url?.includes('/auth/')
+
+        if (error.response?.status === 401 && config && !config._retry && !isAuthRoute) {
+          config._retry = true
+          try {
+            await this.client.post('/auth/refresh')
+            return this.client.request(config)
+          } catch {
+            if (typeof window !== 'undefined') {
+              window.location.href = '/login'
+            }
+          }
+        }
+
+        return Promise.reject(error)
+      }
+    )
+  }
+
+  auth = {
+    login: async (email: string, password: string) => {
+      const { data } = await this.client.post('/auth/login', { email, password })
+      return data
+    },
+
+    register: async (userData: {
+      email: string
+      password: string
+      firstName?: string
+      lastName?: string
+      tenantName?: string
+    }) => {
+      const { data } = await this.client.post('/auth/register', userData)
+      return data
+    },
+
+    logout: async () => {
+      await this.client.post('/auth/logout')
+    },
+
+    getCurrentUser: async () => {
+      const { data } = await this.client.get('/auth/me')
+      return data
+    },
+
+    refresh: async () => {
+      const { data } = await this.client.post('/auth/refresh')
+      return data
+    },
+  }
+
+  dashboard = {
+    getMetrics: async () => {
+      const { data } = await this.client.get('/dashboard/metrics')
+      return data
+    },
+  }
+
+  plans = {
+    list: async () => {
+      const { data } = await this.client.get('/plans')
+      return data
+    },
+  }
+
+  lines = {
+    list: async (params?: {
+      page?: number
+      limit?: number
+      status?: string
+      search?: string
+    }) => {
+      const { data } = await this.client.get('/lines', { params })
+      return data
+    },
+
+    get: async (id: string) => {
+      const { data } = await this.client.get(`/lines/${id}`)
+      return data
+    },
+
+    create: async (lineData: { planId?: string; quantity?: number }) => {
+      const { data } = await this.client.post('/lines', lineData)
+      toast.success(data.message || 'Line provisioning initiated')
+      return data
+    },
+
+    suspend: async (id: string) => {
+      const { data } = await this.client.post(`/lines/${id}/suspend`)
+      toast.success('Line suspended successfully')
+      return data
+    },
+
+    resume: async (id: string) => {
+      const { data } = await this.client.post(`/lines/${id}/resume`)
+      toast.success('Line resumed successfully')
+      return data
+    },
+
+    terminate: async (id: string) => {
+      const { data } = await this.client.delete(`/lines/${id}`)
+      toast.success('Line terminated successfully')
+      return data
+    },
+  }
+
+  audit = {
+    getLogs: async (params?: {
+      page?: number
+      limit?: number
+      action?: string
+      resource?: string
+      actor?: string
+    }) => {
+      const { data } = await this.client.get('/audit', { params })
+      return data
+    },
+  }
+
+  handleError(error: unknown, fallback: string) {
+    if (error instanceof AxiosError) {
+      const message = error.response?.data?.error || fallback
+      toast.error(message)
+      return message
+    }
+
+    toast.error(fallback)
+    return fallback
+  }
+}
+
+export const api = new APIClient()
