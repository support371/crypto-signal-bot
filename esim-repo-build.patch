+    @apply w-full border-collapse;
+  }
+
+  .table thead {
+    @apply border-b border-dark-800;
+  }
+
+  .table th {
+    @apply px-6 py-4 text-left text-sm font-semibold text-dark-300 uppercase tracking-wider;
+  }
+
+  .table td {
+    @apply px-6 py-4 text-sm text-dark-200 border-b border-dark-900;
+  }
+
+  .table tbody tr {
+    @apply hover:bg-dark-900/50 transition-colors duration-150;
+  }
+}
+
+@layer utilities {
+  /* Animation delays */
+  .animation-delay-75 {
+    animation-delay: 75ms;
+  }
+  
+  .animation-delay-150 {
+    animation-delay: 150ms;
+  }
+  
+  .animation-delay-300 {
+    animation-delay: 300ms;
+  }
+  
+  .animation-delay-500 {
+    animation-delay: 500ms;
+  }
+
+  /* Custom grid */
+  .grid-auto-fit {
+    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
+  }
+}
