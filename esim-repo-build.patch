+import { useAuthStore } from '@/lib/auth-store'
+import type { Line, MetricsResponse } from '@/lib/types'
+
+interface MetricCard { label: string; value: string; change: string; trend: 'up' | 'down'; icon: React.ComponentType<{ className?: string }> }
+function getPlanName(line: Line) { return line.lineBundles?.[0]?.bundle?.plan?.name || 'Unassigned' }
+function getUsage(line: Line) { const latest = line.usageRecords?.[0]?.dataUsedMB; if (!latest) return '---'; return `${(latest / 1024).toFixed(1)} GB` }
+function getTimeAgo(date: string) { const seconds = Math.floor((Date.now() - new Date(date).getTime()) / 1000); if (seconds < 60) return 'Just now'; if (seconds < 3600) return `${Math.floor(seconds / 60)} mins ago`; if (seconds < 86400) return `${Math.floor(seconds / 3600)} hours ago`; return `${Math.floor(seconds / 86400)} days ago` }
+const statusColors: Record<Line['status'], string> = { ACTIVE: 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20', PROVISIONING: 'bg-amber-500/10 text-amber-400 border-amber-500/20', SUSPENDED: 'bg-red-500/10 text-red-400 border-red-500/20', TERMINATED: 'bg-gray-500/10 text-gray-400 border-gray-500/20', FAILED: 'bg-red-500/10 text-red-400 border-red-500/20' }
+
+export default function DashboardPage() {
