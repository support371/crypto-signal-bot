+import 'dotenv/config';
+import app from './app';
+import { logger } from './lib/logger';
+import { initializeQueues } from './jobs/queues';
+
+const PORT = Number(process.env.PORT || 3001);
+const NODE_ENV = process.env.NODE_ENV || 'development';
+const requiredEnv = ['DATABASE_URL', 'JWT_SECRET', 'REFRESH_TOKEN_SECRET'];
+
+function validateEnvironment() {
+  const missing = requiredEnv.filter((key) => !process.env[key]);
+
+  if (missing.length > 0) {
+    throw new Error(`Missing required environment variables: ${missing.join(', ')}`);
+  }
+}
+
+async function startServer() {
+  try {
+    validateEnvironment();
+    await initializeQueues();
+    logger.info('Job queues initialized');
+
+    app.listen(PORT, () => {
+      logger.info('🚀 eSIM Platform API Server');
+      logger.info('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━');
+      logger.info(`Environment: ${NODE_ENV}`);
+      logger.info(`Server running on port ${PORT}`);
+      logger.info(`Health check: http://localhost:${PORT}/health`);
+      logger.info(`Liveness check: http://localhost:${PORT}/health/live`);
+      logger.info(`Readiness check: http://localhost:${PORT}/health/ready`);
+      logger.info(`API Base: http://localhost:${PORT}/api`);
+      logger.info('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━');
+    });
+  } catch (error) {
+    logger.error('Failed to start server', { error });
+    process.exit(1);
+  }
+}
+
+void startServer();
