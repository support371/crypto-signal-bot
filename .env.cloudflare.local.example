# Cloudflare local-only credentials template.
# Copy this file to .env.cloudflare.local and paste your real values there.
# Do not commit .env.cloudflare.local.

# Required by Wrangler for account-level Cloudflare operations.
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""

# Optional R2 S3-compatible credentials.
# These are not required for normal Wrangler Worker deployment.
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_S3_ENDPOINT=""
