# Full-stack deployment environment — copy to .env and adjust as needed.
# Docker Compose automatically reads .env from the repo root.

# ── Trading mode ──────────────────────────────────────────────────────────────
# paper | live
TRADING_MODE=paper
# false = synthetic paper pricing, true = paper execution with live Binance public market data
PAPER_USE_LIVE_MARKET_DATA=false
# testnet | mainnet
NETWORK=testnet

# ── Authentication ────────────────────────────────────────────────────────────
# Set to restrict POST endpoints; leave empty for open dev mode.
BACKEND_API_KEY=

# ── Exchange credentials (live mode only) ─────────────────────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=
# Set to "true" ONLY when intentionally using mainnet with real funds.
ALLOW_MAINNET=

# ── Frontend routing ──────────────────────────────────────────────────────────
VITE_BACKEND_URL=/api
VITE_API_BASE_URL=/api

# ── Optional Supabase frontend auth / edge functions ─────────────────────────
# Leave empty for local paper-mode without Supabase.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:8080

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_RPM=120

# ── Guardian thresholds ───────────────────────────────────────────────────────
GUARDIAN_MAX_API_ERRORS=10
GUARDIAN_MAX_FAILED_ORDERS=5
GUARDIAN_MAX_DRAWDOWN_PCT=0.05
