# Full-stack deployment environment — copy to .env and adjust as needed.
# Used by: docker compose -f docker-compose.fullstack.yml --env-file .env up

# ── Trading mode ──────────────────────────────────────────────────────────────
TRADING_MODE=paper        # paper | live
NETWORK=testnet           # testnet | mainnet

# ── Authentication ────────────────────────────────────────────────────────────
BACKEND_API_KEY=          # Set to restrict POST endpoints; leave empty for open dev mode

# ── Exchange credentials (live mode only) ─────────────────────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=
ALLOW_MAINNET=            # Set to "true" ONLY when intentionally using mainnet with real funds

# ── Frontend routing ──────────────────────────────────────────────────────────
VITE_BACKEND_URL=/api
VITE_API_BASE_URL=/api

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:8080

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_RPM=120

# ── Guardian thresholds ───────────────────────────────────────────────────────
GUARDIAN_MAX_API_ERRORS=10
GUARDIAN_MAX_FAILED_ORDERS=5
GUARDIAN_MAX_DRAWDOWN_PCT=0.05
