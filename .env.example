# ── Frontend deployment env ───────────────────────────────────────────────────
#
# These VITE_* variables are baked into the frontend bundle at build time.
# Set them in your hosting platform's environment (Vercel, Netlify, etc.)
# before each deployment.
#
# Local development:
#   VITE_BACKEND_URL=http://localhost:8000
#   VITE_WS_URL=ws://localhost:8000/ws
#
# Vercel / production:
#   VITE_BACKEND_URL=https://crypto-signal-bot-deqd.onrender.com
#   VITE_WS_URL=wss://crypto-signal-bot-deqd.onrender.com/ws
#
# The frontend fetches all API data from VITE_BACKEND_URL.  It must point
# to the backend host and NOT include a trailing slash.
VITE_BACKEND_URL=http://localhost:8000

# WebSocket URL — auto-derived from VITE_BACKEND_URL if omitted.
# Set explicitly if your WS path differs from the REST endpoint.
VITE_WS_URL=

# Alias used by some frontend hooks — should match VITE_BACKEND_URL.
VITE_CRYPTOCORE_API_BASE=http://localhost:8000

# Demo mode — disables Supabase auth and enables paper-only mode.
# Defaults to true in production builds when Supabase is not configured.
VITE_DEMO_MODE=true

# Optional — Supabase auth (leave blank to use API-key auth only).
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# ── Backend exchange selection (set these on the backend host) ────────────────
# EXCHANGE=binance|bitget|btcc
# MARKET_DATA_PUBLIC_EXCHANGE=binance|bitget|btcc
#
# Live market data in paper mode — uses Binance public API for real prices.
# Default: true (config.yaml). Set to false to use synthetic price simulation.
# PAPER_USE_LIVE_MARKET_DATA=true

# ── Database (backend) ───────────────────────────────────────────────────────
# Default: SQLite (local development)
#   DATABASE_URL=sqlite:///./crypto_bot.db
#
# Production (PostgreSQL via Supabase / Neon):
#   DATABASE_URL=postgresql://user:password@host:port/dbname
DATABASE_URL=sqlite:///./crypto_bot.db
