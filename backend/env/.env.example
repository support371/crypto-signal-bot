# Crypto Signal Bot — Backend Environment
# Copy this file to backend/env/.env and fill in real values.
# Never commit .env to git.

# ── Trading mode ─────────────────────────────────────────────────────────────
# "paper"  → fully simulated, no exchange connection (default, always safe)
# "live"   → routes to testnet or mainnet depending on NETWORK below
TRADING_MODE=paper

# ── Network ──────────────────────────────────────────────────────────────────
# "testnet"  → Binance Spot Testnet (https://testnet.binance.vision)
# "mainnet"  → Binance production API  ⚠ REAL FUNDS
NETWORK=testnet

# ── Exchange credentials ──────────────────────────────────────────────────────
# Required only when TRADING_MODE=live.
# For testnet keys, register at https://testnet.binance.vision
# For mainnet keys, register at https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Authentication ────────────────────────────────────────────────────────────
# Set to restrict POST endpoints (kill-switch, intents, withdraw, earnings/reset).
# Leave empty to run open in development mode.
BACKEND_API_KEY=

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:3000

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_RPM=120

# ── Guardian thresholds ───────────────────────────────────────────────────────
GUARDIAN_MAX_API_ERRORS=10
GUARDIAN_MAX_FAILED_ORDERS=5
GUARDIAN_MAX_DRAWDOWN_PCT=0.05

# ── Persistence ───────────────────────────────────────────────────────────────
AUDIT_STORE_PATH=backend/data/audit.json
EARNINGS_STORE_PATH=backend/data/earnings.json

# ── Testnet quick-start ───────────────────────────────────────────────────────
# 1. Install ccxt:          pip install ccxt
# 2. Get testnet keys:      https://testnet.binance.vision  (free, no real funds)
# 3. Set above:             TRADING_MODE=live  NETWORK=testnet
# 4. Fill in:               BINANCE_API_KEY and BINANCE_API_SECRET
# 5. Start backend:         uvicorn backend.app:app --reload --port 8000
# The adapter field on GET /health and GET /config will show "testnet" when active.
