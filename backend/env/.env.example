# Crypto Signal Bot — Backend Environment
# Copy this file to backend/env/.env and fill in real values.
# Never commit .env to git.

# ── Trading mode ─────────────────────────────────────────────────────────────
# "paper"  → fully simulated, no exchange connection (default, always safe)
# "live"   → routes to testnet or mainnet depending on NETWORK below
TRADING_MODE=paper

# Exchange selected for authenticated live execution when TRADING_MODE=live.
# Supported: binance | bitget | btcc
EXCHANGE=binance

# When true and TRADING_MODE=paper, execution stays paper but prices/signals use
# selected live public market data.
PAPER_USE_LIVE_MARKET_DATA=false

# Optional explicit public market-data venue for hybrid paper mode.
# Defaults to EXCHANGE when unset.
MARKET_DATA_PUBLIC_EXCHANGE=binance

# ── Network ──────────────────────────────────────────────────────────────────
# "testnet"  → certification/demo path
# "mainnet"  → production API  ⚠ REAL FUNDS
NETWORK=testnet

# ── Exchange credentials ──────────────────────────────────────────────────────
# Required only when TRADING_MODE=live.
# Binance:
BINANCE_API_KEY=
BINANCE_API_SECRET=
# Bitget:
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=
# BTCC:
BTCC_API_KEY=
BTCC_API_SECRET=

# ── Authentication ────────────────────────────────────────────────────────────
# Set to restrict POST endpoints (kill-switch, intents, withdraw, earnings/reset).
# Leave empty to run open in development mode.
BACKEND_API_KEY=

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:3000

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_RPM=120

# ── Guardian thresholds ───────────────────────────────────────────────────────
GUARDIAN_MAX_API_ERRORS=10
GUARDIAN_MAX_FAILED_ORDERS=5
GUARDIAN_MAX_DRAWDOWN_PCT=0.05

# ── Persistence ───────────────────────────────────────────────────────────────
AUDIT_STORE_PATH=backend/data/audit.json
EARNINGS_STORE_PATH=backend/data/earnings.json

# ── Testnet quick-start ───────────────────────────────────────────────────────
# Synthetic paper:
#   TRADING_MODE=paper
#   EXCHANGE=binance
#   PAPER_USE_LIVE_MARKET_DATA=false
#
# Hybrid live-paper:
#   TRADING_MODE=paper
#   EXCHANGE=binance
#   PAPER_USE_LIVE_MARKET_DATA=true
#
# Live certification:
# 1. Install ccxt:          pip install ccxt
# 2. Set above:             TRADING_MODE=live  NETWORK=testnet  EXCHANGE=binance|bitget|btcc
# 3. Fill in matching creds for the selected EXCHANGE
# 4. Start backend:         uvicorn backend.app:app --reload --port 8000
# The adapter field on GET /health and GET /config will show "testnet" when active.
