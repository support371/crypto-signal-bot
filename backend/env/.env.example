# Crypto Signal Bot — Backend
# Environment variables for local development.
# Copy to .env and fill in real values.

# Trading mode: "paper" (default) or "live"
TRADING_MODE=paper

# Network: "testnet" (default) or "mainnet"
NETWORK=testnet

# Binance API credentials (only needed for live mode)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:3000

# Audit store path
AUDIT_STORE_PATH=backend/data/audit.json
