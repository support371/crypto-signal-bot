# ============================================================
# Production Environment Variables — crypto-signal-bot backend
# ============================================================
# Copy this to .env and fill in all required values.
# NEVER commit a .env with real credentials.
# ============================================================

# ---- Execution mode ----
TRADING_MODE=paper
# Use "live" only after full testnet certification
# TRADING_MODE=live

NETWORK=testnet
EXCHANGE=binance
MARKET_DATA_PUBLIC_EXCHANGE=binance
PAPER_USE_LIVE_MARKET_DATA=true

# ---- Database (REQUIRED for production — use PostgreSQL) ----
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/crypto_bot
# For local dev only:
# DATABASE_URL=sqlite+aiosqlite:///./crypto_bot.db

# ---- Redis (REQUIRED for production) ----
# Multi-worker rate limiting, kill switch state, pub/sub
REDIS_URL=redis://:your-redis-password@your-redis-host:6379/0

# ---- Auth (REQUIRED for production) ----
# Protects all write endpoints (kill-switch, intents, risk config)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
BACKEND_API_KEY=your-secret-operator-key-here

# ---- Exchange credentials (only needed for TRADING_MODE=live) ----
# Binance
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
# BINANCE_TESTNET=true

# Bitget
# BITGET_API_KEY=
# BITGET_API_SECRET=
# BITGET_PASSPHRASE=

# BTCC
# BTCC_API_KEY=
# BTCC_API_SECRET=

# ---- CORS (REQUIRED — must match your Vercel frontend URL exactly) ----
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
# Multiple origins (comma-separated):
# CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://your-custom-domain.com

# ---- Persistence paths ----
AUDIT_STORE_PATH=/tmp/crypto-signal-bot/audit.json
EARNINGS_STORE_PATH=/tmp/crypto-signal-bot/earnings.json
EVENT_LOG_PATH=/tmp/crypto-signal-bot/event_log.db

# ---- Rate limiting ----
RATE_LIMIT_RPM=120

# ---- Guardian thresholds ----
GUARDIAN_MAX_DRAWDOWN_PCT=5.0
GUARDIAN_MAX_API_ERRORS=10
GUARDIAN_MAX_FAILED_ORDERS=5

# ---- Metrics ----
METRICS_ENABLED=true
